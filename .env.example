POSTGRES_DB=auth
POSTGRES_USER=auth
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
POSTGRES_SERVER=auth_rs_db_postgres

# Frontend/consumer origins that will call this auth service. JSON array or comma-separated.
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# JWT settings. JWT_AUDIENCE must match what token-verifying services expect.
JWT_ISSUER=auth-svc
JWT_AUDIENCE=your-service
JWT_PRIVATE_KEY_PATH=/app/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/jwt_public.pem

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

DEFAULT_USER_GROUPS={"ADMIN":"ADMIN","MAINTENANCE":"MAINTENANCE","READ_ONLY":"READ_ONLY"}

SUPERUSER_EMAILS=["admin@example.com"]

# Listen address + log level
ADDR=0.0.0.0:8001
RUST_LOG=auth_rs=info,tower_http=info
